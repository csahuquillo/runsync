# Plantilla para .claude/env.local (copia este archivo a env.local y rellena).
# env.local está gitignored: NO se commitea. Aquí van los datos para que el
# slash command /status pueda hablar con INVENT vía AWS SSM.
#
#   cp .claude/env.local.example .claude/env.local
#
# Id de la instancia EC2 donde corre INVENT (i-0XXXXXXXXXXXXXXXX).
INVENT_INSTANCE_ID=i-0XXXXXXXXXXXXXXXX
# Perfil AWS local con permiso ssm:SendCommand sobre esa instancia.
AWS_PROFILE=tu-perfil-aws
# Región (opcional; por defecto eu-west-3).
AWS_REGION=eu-west-3
